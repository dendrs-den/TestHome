{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "InflightFlow Operator",
    "version":  "0.1.0",
    "identifier":  "com.inflightflow.operator",
    "build":  {
                  "beforeDevCommand":  "npm run dev:tauri",
                  "beforeBuildCommand":  "npm run build",
                  "devUrl":  "http://127.0.0.1:5188",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "InflightFlow Operator",
                                    "width":  1920,
                                    "height":  1080,
                                    "minWidth":  1280,
                                    "minHeight":  720,
                                    "maximized":  true,
                                    "resizable":  true
                                }
                            ]
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all"
               }
}
